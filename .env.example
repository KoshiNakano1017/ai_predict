# ============================================================
# バッチ / AI実行基盤 環境変数
# !! 実際の値をコミットしないこと。.env は .gitignore に含めること !!
# ============================================================

# ──────────────────────────────────────
# Supabase（公開側 / Web表示用）
# service_role キー: バッチ側専用。フロント側には公開しない
# ──────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ──────────────────────────────────────
# VM 内 PostgreSQL（AI用 / keiba_ai DB）
# 個別指定か DSN 文字列のいずれかを設定する
# ──────────────────────────────────────
AI_DB_HOST=localhost
AI_DB_PORT=5432
AI_DB_NAME=keiba_ai
AI_DB_USER=ai_runner
AI_DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
# DSN を直接指定する場合（こちらが優先される）
# AI_DB_DSN=host=localhost port=5432 dbname=keiba_ai user=ai_runner password=xxx

# ──────────────────────────────────────
# GCP / GCS
# ──────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
GCS_BUCKET=your-gcs-bucket-name
# バックアップ世代管理（日数）
BACKUP_RETENTION_DAYS=14
GCS_BACKUP_RETENTION_DAYS=30

# ──────────────────────────────────────
# モデルバージョン管理
# 推論時に Supabase entries.model_version として記録される
# ──────────────────────────────────────
MODEL_VERSION=v1.0.0

# ──────────────────────────────────────
# メール通知（SMTP）
# ──────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
MAIL_FROM=your-email@gmail.com
MAIL_TO=client@example.com,dev@example.com
