[Unit]
Description=CrossFactor AI - pre_race pipeline
After=network.target postgresql.service
Requires=postgresql.service

[Service]
Type=oneshot
User=ubuntu
WorkingDirectory=/opt/keiba-ai
EnvironmentFile=/opt/keiba-ai/.env
ExecStart=/opt/keiba-ai/.venv/bin/python batch/run_pipeline_vm.py --mode pre_race
StandardOutput=append:/opt/keiba-ai/logs/pre_race.log
StandardError=append:/opt/keiba-ai/logs/pre_race.log
TimeoutStartSec=3600
